# Grafida — test configuration sample.
#
# Copy this file to `tests/.env` (which is gitignored) and fill it in. It is
# OPTIONAL: without it the live provider tests skip and the suite still passes.
#
#     cp tests/.env.sample tests/.env
#
# See tests/README.md for what these tests actually do and how to run them.
# A variable exported in your real environment overrides the value set here.


# ---------------------------------------------------------------------------
#  Live OpenAI *Responses API* provider
#  Used by tests/Integration/Ai/ResponsesApiLiveTest.php.
#  Both ENDPOINT and MODEL must be set or the tests skip.
# ---------------------------------------------------------------------------

# Base URL of the provider, WITHOUT the /responses path (the test appends it).
GRAFIDA_TEST_RESPONSES_ENDPOINT="https://api.openai.com/v1"

# The model to ask. It must support the Responses API.
GRAFIDA_TEST_RESPONSES_MODEL="gpt-4o-mini"

# API key. Leave empty for a local server (LM Studio, vLLM, …) that needs no auth.
GRAFIDA_TEST_RESPONSES_KEY=""

# Which providers.json key to build the test service from. This only affects
# AiProxy's host allow-listing, so the default suits any endpoint; use "openai"
# to exercise that preset instead.
GRAFIDA_TEST_RESPONSES_PROVIDER="custom_responses"


# --- A local LM Studio server instead of OpenAI (no key required) -------------
#
# GRAFIDA_TEST_RESPONSES_ENDPOINT="http://192.168.1.10:1234/v1"
# GRAFIDA_TEST_RESPONSES_MODEL="openai/gpt-oss-20b"
# GRAFIDA_TEST_RESPONSES_KEY=""
